{
  "meta": {
    "name": "resume_aidesu-design-tokens",
    "version": "1.0.0"
  },
  "colors": {
    "sumi-black": "#1f2933",
    "nezumi-gray": "#62707a",
    "kinari-off-white": "#f4f2ed",
    "akane-red": "#b54a4a",
    "ai-blue": "#24546a",
    "background": "var(--wa-colors-kinari-off-white)",
    "foreground": "var(--wa-colors-sumi-black)",
    "surface": "#fdfcf9",
    "surface-muted": "#f7f4ee",
    "border": "color-mix(in oklab, var(--wa-colors-nezumi-gray) 34%, white)",
    "ring": "color-mix(in oklab, var(--wa-colors-ai-blue) 72%, white)",
    "success": "#2f7a52",
    "danger": "#b54a4a",
    "muted-foreground": "color-mix(in oklab, var(--wa-colors-nezumi-gray) 88%, white)"
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem",
    "xl": "1.5rem"
  },
  "radii": {
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem"
  },
  "typography": {
    "size-sm": "0.875rem",
    "size-base": "1rem",
    "size-lg": "1.125rem",
    "line-tight": "1.4",
    "line-normal": "1.65"
  },
  "elevation": {
    "surface": "0 3px 12px rgba(18, 29, 38, 0.055), inset 0 1px 0 rgba(255, 255, 255, 0.55)",
    "lift": "0 8px 22px rgba(18, 29, 38, 0.095)"
  },
  "motion": {
    "dur-fast": "140ms",
    "dur-normal": "220ms",
    "dur-reduced-fast": "80ms",
    "dur-reduced-normal": "120ms",
    "ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
    "ease-spring-ui": "var(--wa-motion-ease-standard)",
    "ease-spring-enter": "var(--wa-motion-ease-standard)",
    "ease-spring-exit": "var(--wa-motion-ease-standard)"
  }
}
