{
  "meta": {
    "name": "resume_aidesu-design-tokens",
    "version": "1.0.0"
  },
  "colors": {
    "sumi-black": "#111827",
    "nezumi-gray": "#4b5563",
    "kinari-off-white": "#f7f7f4",
    "akane-red": "#d14343",
    "ai-blue": "#06c755",
    "background": "var(--wa-colors-kinari-off-white)",
    "foreground": "var(--wa-colors-sumi-black)",
    "surface": "#ffffff",
    "surface-muted": "#f3f7f3",
    "border": "color-mix(in oklab, var(--wa-colors-nezumi-gray) 24%, white)",
    "ring": "color-mix(in oklab, var(--wa-colors-ai-blue) 78%, white)",
    "success": "#16a34a",
    "danger": "#d14343",
    "muted-foreground": "color-mix(in oklab, var(--wa-colors-nezumi-gray) 88%, white)"
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem",
    "xl": "1.5rem"
  },
  "radii": {
    "sm": "0.5rem",
    "md": "0.75rem",
    "lg": "1rem"
  },
  "typography": {
    "size-sm": "0.875rem",
    "size-base": "1rem",
    "size-lg": "1.125rem",
    "line-tight": "1.4",
    "line-normal": "1.65"
  },
  "elevation": {
    "surface": "0 6px 18px rgba(17, 24, 39, 0.07), inset 0 1px 0 rgba(255, 255, 255, 0.8)",
    "lift": "0 12px 30px rgba(17, 24, 39, 0.14)"
  },
  "motion": {
    "dur-fast": "140ms",
    "dur-normal": "220ms",
    "dur-reduced-fast": "80ms",
    "dur-reduced-normal": "120ms",
    "ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
    "ease-spring-ui": "var(--wa-motion-ease-standard)",
    "ease-spring-enter": "var(--wa-motion-ease-standard)",
    "ease-spring-exit": "var(--wa-motion-ease-standard)"
  }
}
